# vim:fileencoding=utf-8:foldmethod=marker

include ./theme.conf
# font_family MapleMono Nerd Font
# font_family Caskaydia Code Nerd Font
# font_family Myna
font_size 12.0
kitty_mod cmd
map kitty_mod+t no_op
macos_option_as_alt yes
term xterm-256color


# BEGIN_KITTY_FONTS
font_family      family="PT Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS